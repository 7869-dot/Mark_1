# ─────────────────────────────────────────────
#  TWIN AGENT — environment variable template
#  Copy this to .env and fill in your values.
#  NEVER commit .env to git.
# ─────────────────────────────────────────────

# ── LLM provider (at least one required) ─────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Which model to use as the backbone
# Options: gpt-4o | gpt-4-turbo | claude-3-5-sonnet-20241022 | gpt-4o-mini
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096

# ── Agent identity ────────────────────────────
AGENT_NAME=twin
# Persona context — who this twin represents
PERSONA_DESCRIPTION="A highly capable AI assistant that acts on behalf of its owner."
MAX_AGENT_ITERATIONS=15
MAX_CONTEXT_TOKENS=120000

# ── Memory ────────────────────────────────────
DATABASE_URL=sqlite:///./data/agent_memory.db
CHROMA_PERSIST_PATH=./data/chroma_db
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Gmail ─────────────────────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8000/auth/gmail/callback
# Path to the token file generated after first OAuth flow
GMAIL_TOKEN_PATH=./data/gmail_token.json

# ── Slack ─────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=

# ── Twitter / X ───────────────────────────────
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_BEARER_TOKEN=

# ── API server ────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-this-to-a-random-string
DEBUG=true
