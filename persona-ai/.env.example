# Application
APP_NAME=persona-ai
ENVIRONMENT=development
DEBUG=false
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Database (async driver for the app; Alembic uses sync URL derived from this)
DATABASE_URL=postgresql+asyncpg://persona:persona@localhost:5432/persona

# Security
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ALGORITHM=HS256

# CORS (comma-separated origins; use * only in local dev)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate limits
RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_AUTH=30/minute

# Embeddings (OpenAI-compatible API)
EMBEDDING_API_KEY=
EMBEDDING_API_BASE=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Optional: disable external embedding calls (uses deterministic pseudo-vectors; dev/demo only)
EMBEDDING_FAKE=false
